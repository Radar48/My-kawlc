<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/pinkBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Display -->
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/display_bg"
        android:textColor="@color/black"
        android:textSize="36sp"
        android:gravity="end|center_vertical"
        android:padding="16dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:scrollHorizontally="true"
        android:focusable="false"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Buttons -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:alignmentMode="alignMargins"
        android:rowOrderPreserved="false"
        android:columnOrderPreserved="false"
        android:layout_gravity="bottom">

        <!-- Row 1 -->
        <Button
            android:id="@+id/btnClear"
            android:text="🩷"
            style="@style/CalcButton"
            android:background="@drawable/btn_clear"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>

        <Button
            android:id="@+id/btnDivide"
            android:text="➗"
            style="@style/CalcButton"
            android:background="@drawable/btn_divide"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>

        <Button
            android:id="@+id/btnMultiply"
            android:text="✖️"
            style="@style/CalcButton"
            android:background="@drawable/btn_multiply"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>

        <Button
            android:id="@+id/btnSubtract"
            android:text="➖"
            style="@style/CalcButton"
            android:background="@drawable/btn_subtract"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>

        <!-- Row 2 -->
        <Button
            android:id="@+id/btn7"
            android:text="7"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btn8"
            android:text="8"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btn9"
            android:text="9"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btnAdd"
            android:text="➕"
            style="@style/CalcButton"
            android:background="@drawable/btn_add"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>

        <!-- Row 3 -->
        <Button
            android:id="@+id/btn4"
            android:text="4"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btn5"
            android:text="5"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btn6"
            android:text="6"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btnEquals"
            android:text="🟰"
            style="@style/CalcButton"
            android:background="@drawable/btn_equals"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:layout_rowSpan="2"/>

        <!-- Row 4 -->
        <Button
            android:id="@+id/btn1"
            android:text="1"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btn2"
            android:text="2"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"/>
        <Button
            android:id="@+id/btn3"
            android:text="3"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            tools:ignore="HardcodedText" />

        <!-- Row 5 -->
        <Button
            android:id="@+id/btn0"
            android:text="0"
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:layout_columnSpan="2"
            tools:ignore="HardcodedText" />
        <Button
            android:id="@+id/btnDot"
            android:text="."
            style="@style/CalcButton"
            android:background="@drawable/btn_number"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            tools:ignore="HardcodedText" />

    </GridLayout>
</LinearLayout>